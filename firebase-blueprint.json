{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A piece of content published by an admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title or headline of the post." },
        "content": { "type": "string", "description": "The main text or body of the post." },
        "type": { 
          "type": "string", 
          "enum": ["news", "gallery", "music", "ads", "products", "videos"],
          "description": "The category of the content." 
        },
        "mediaUrl": { "type": "string", "description": "URL to the media asset (image, video, audio)." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "List of comma separated tags." },
        "authorId": { "type": "string", "description": "UID of the admin who posted this." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation." }
      },
      "required": ["title", "type", "authorId", "createdAt"]
    },
    "GroupMessage": {
      "title": "Group Message",
      "description": "A message sent in the AI Party group chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string" },
        "senderId": { "type": "string" },
        "type": { "type": "string", "enum": ["user", "ai"] },
        "avatar": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "sender", "senderId", "type", "createdAt"]
    },
    "SocialPost": {
      "title": "Social Post",
      "description": "A post or reel created by a user in the social feed.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Text content of the post." },
        "type": { "type": "string", "enum": ["post", "reel"], "description": "Content type." },
        "mediaUrl": { "type": "string", "description": "Photo or video URL." },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "likesCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "type", "authorId", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Public stream of all content published by administrators."
    },
    "/social_posts/{postId}": {
      "schema": "SocialPost",
      "description": "User-generated social feed items."
    },
    "/social_posts/{postId}/likes/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Likes on a social post."
    },
    "/group_messages/{messageId}": {
      "schema": "GroupMessage",
      "description": "Messages for the AI Party group chat room."
    }
  }
}
