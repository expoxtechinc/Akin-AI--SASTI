{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User security settings and status.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "deviceName": { "type": "string" },
        "shieldEnabled": { "type": "boolean" },
        "gpsTrackingActive": { "type": "boolean" },
        "vpnStatus": { "type": "string", "enum": ["connected", "disconnected", "error"] },
        "lastScanAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "SecurityLog": {
      "title": "Security Log",
      "description": "Log of security events like intruder attempts or wrong passwords.",
      "type": "object",
      "properties": {
        "logId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["intruder_alert", "wrong_password", "malware_detected", "system_breach"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "imageUrl": { "type": "string", "description": "URL to intruder selfie" }
      },
      "required": ["userId", "type", "timestamp"]
    },
    "VaultFile": {
      "title": "Vault File",
      "description": "Metadata for a file stored in the secure vault.",
      "type": "object",
      "properties": {
        "fileId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "number" },
        "encryptedData": { "type": "string" },
        "mimeType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "encryptedData"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "Conversation threads with AkinAI.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "personality": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "messages": {
          "type": "array"
        }
      },
      "required": ["title", "personality"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles and settings."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "SecurityLog",
      "description": "Security event logs for a specific user."
    },
    "/users/{userId}/vault/{fileId}": {
      "schema": "VaultFile",
      "description": "Encrypted files in the user's private vault."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Stored chat session threads for a specific user under AkinAI."
    }
  }
}
