rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // PHASE 3 Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return isSignedIn() 
        && request.auth.token.email == 'luckyglobalnews@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for Post
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'authorId', 'createdAt'])
        && data.keys().size() <= 7 // title, content, type, mediaUrl, tags, authorId, createdAt
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 5000
        && data.type in ['news', 'gallery', 'music', 'ads', 'products', 'videos']
        && data.authorId == request.auth.uid
        && data.createdAt == request.time
        && (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 1000))
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 20));
    }

    function isValidGroupMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'senderId', 'type', 'createdAt'])
        && data.keys().size() <= 7
        && data.text is string && data.text.size() <= 1000
        && data.sender is string && data.sender.size() <= 100
        && data.senderId is string && data.senderId.size() <= 128
        && data.type in ['user', 'ai']
        && data.createdAt == request.time;
    }

    function isValidSocialPost(data) {
      return data.keys().hasAll(['content', 'type', 'authorId', 'authorName', 'createdAt'])
        && data.keys().size() <= 8
        && data.content is string && data.content.size() <= 2000
        && data.type in ['post', 'reel']
        && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() <= 100
        && (!('authorAvatar' in data) || (data.authorAvatar is string && data.authorAvatar.size() <= 1000))
        && (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 1000))
        && data.likesCount is number
        && data.createdAt == request.time;
    }

    match /posts/{postId} {
      // 3. Path Variable Hardening
      allow get: if isValidId(postId);
      
      // 8. Secure List Queries
      allow list: if true; // Everyone can see news/media

      allow create: if isVerifiedAdmin() && isValidPost(incoming());
      
      allow update: if isVerifiedAdmin() 
        && isValidPost(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          // Action: General Update
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'mediaUrl', 'tags', 'type'])
        );

      allow delete: if isVerifiedAdmin();
    }

    match /social_posts/{postId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidSocialPost(incoming());
      allow update: if isSignedIn() 
        && isValidSocialPost(incoming())
        && incoming().authorId == existing().authorId
        && (
          // Action: Edit content
          (incoming().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrl'])) ||
          // Action: Like (Atomic counter update)
          (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && (incoming().likesCount == existing().likesCount + 1 || incoming().likesCount == existing().likesCount - 1))
        );
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;

      match /likes/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && userId == request.auth.uid;
      }
    }

    match /group_messages/{messageId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidGroupMessage(incoming()) && (
        (incoming().type == 'user' && incoming().senderId == request.auth.uid) ||
        (incoming().type == 'ai') // In a demo, we allow AI messages or would use a Cloud Function/Admin SDK
      );
    }
  }
}
