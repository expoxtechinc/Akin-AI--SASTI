rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // PHASE 3 Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'email'])
        && data.keys().size() <= 10
        && data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && (!('deviceName' in data) || (data.deviceName is string && data.deviceName.size() <= 100))
        && (!('shieldEnabled' in data) || data.shieldEnabled is bool)
        && (!('gpsTrackingActive' in data) || data.gpsTrackingActive is bool)
        && (!('vpnStatus' in data) || data.vpnStatus in ['connected', 'disconnected', 'error'])
        && (!('lastScanAt' in data) || data.lastScanAt is timestamp);
    }

    function isValidSecurityLog(data) {
      return data.keys().hasAll(['userId', 'type', 'timestamp'])
        && data.keys().size() <= 8
        && data.userId == request.auth.uid
        && data.type in ['intruder_alert', 'wrong_password', 'malware_detected', 'system_breach', 'vpn_anomaly']
        && data.timestamp == request.time
        && (!('description' in data) || (data.description is string && data.description.size() <= 1000))
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    function isValidVaultFile(data) {
      return data.keys().hasAll(['userId', 'name', 'encryptedData'])
        && data.keys().size() <= 10
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 255
        && data.encryptedData is string && data.encryptedData.size() <= 1000000 // 1MB limit for field
        && (!('size' in data) || data.size is number)
        && (!('mimeType' in data) || (data.mimeType is string && data.mimeType.size() <= 100))
        && (!('createdAt' in data) || data.createdAt == request.time);
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isValidId(userId) && isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming())
        && incoming().userId == existing().userId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['email', 'deviceName', 'shieldEnabled', 'gpsTrackingActive', 'vpnStatus', 'lastScanAt'])
        );
      allow delete: if isOwner(userId);

      match /logs/{logId} {
        allow get: if isValidId(logId) && isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSecurityLog(incoming());
        allow delete: if isOwner(userId);
      }

      match /vault/{fileId} {
        allow get: if isValidId(fileId) && isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidVaultFile(incoming());
        allow update: if isOwner(userId) && isValidVaultFile(incoming())
          && incoming().userId == existing().userId
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'encryptedData', 'size', 'mimeType'])
          );
        allow delete: if isOwner(userId);
      }
    }
  }
}
